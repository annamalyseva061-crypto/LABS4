using System;

namespace ForRowOfTwenty
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Title = "Работа 4. for - Ряд чисел 20";
            
            Console.Write("Введите длину ряда N: ");
            int N = int.Parse(Console.ReadLine());
            
            Console.Write("\nРезультат: ");
            
            for (int i = 0; i < N; i++)
            {
                Console.Write("20 ");
            }
            
            Console.WriteLine($"\n(Длина ряда {N})");
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
