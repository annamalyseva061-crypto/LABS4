using System;

namespace ForAlternatingSeries
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Title = "Работа 4. for - Знакопеременный ряд";
            
            Console.Write("Введите n: ");
            int n = int.Parse(Console.ReadLine());
            
            double sum = 0;
            
            Console.WriteLine($"\nВычисление суммы 1 - 1/2 + 1/3 - ... + (-1)^(n+1)/n");
            Console.WriteLine($"n = {n}\n");
            
            for (int i = 1; i <= n; i++)
            {
                double term = 1.0 / i;
                
                if (i % 2 == 0)
                {
                    sum -= term;
                    Console.WriteLine($"Член {i}: -1/{i} = -{term:F4}");
                }
                else
                {
                    sum += term;
                    Console.WriteLine($"Член {i}: +1/{i} = +{term:F4}");
                }
            }
            
            Console.WriteLine($"\nСумма ряда = {sum:F6}");
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
